<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <PreferenceCategory
        android:title="Authentication">
        <EditTextPreference
            android:key="username"
            android:title="Username"
            android:defaultValue=""
            android:singleLine="true" />
        <EditTextPreference
            android:key="password"
            android:title="Password"
            android:defaultValue=""
            android:inputType="textPassword"
            android:singleLine="true" />
    </PreferenceCategory>

    <PreferenceCategory android:title="Certificate Settings">
        <Preference
            android:key="certificate_path"
            android:title="Custom TLS Certificate" android:summary="Select your own certificate" android:persistent="true" />
        <EditTextPreference
            android:key="certificate_password"
            android:title="Certificate Password"
            android:summary="Optional password for the TLS certificate"
            android:persistent="true"
            android:inputType="textPassword" />
        <Preference
            android:key="test_certificate"
            android:title="Test Certificate Setup"
            android:summary="Validate your certificate configuration"
            android:persistent="false" />
    </PreferenceCategory>

    <PreferenceCategory android:title="Power Saving">
        <SwitchPreferenceCompat
            android:key="power_saving_mode"
            android:title="Power Saving Mode"
            android:summary="Force lowest quality and frame rate to save battery"
            android:defaultValue="false" />
    </PreferenceCategory>

    <PreferenceCategory android:title="Camera Settings">
        <ListPreference
            android:key="camera_resolution"
            android:title="Resolution"
            android:summary="Higher resolution requires more bandwidth"
            android:entries="@array/resolution_entries"
            android:entryValues="@array/resolution_values"
            android:defaultValue="low" />
        <EditTextPreference
            android:key="camera_zoom"
            android:title="Digital Zoom"
            android:summary="Default 1.0 (0.5 - 2.0)"
            android:defaultValue="1.0"
            android:inputType="numberDecimal" />
        <EditTextPreference
            android:key="camera_exposure"
            android:title="Exposure Compensation"
            android:summary="Adjust brightness (-2 to +2)"
            android:defaultValue="0"
            android:inputType="numberSigned" />
        <EditTextPreference
            android:key="camera_contrast"
            android:title="Contrast"
            android:summary="Software-based contrast adjustment (-50 to 50)"
            android:defaultValue="0"
            android:inputType="numberSigned" />
        <EditTextPreference
            android:key="camera_torch_strength"
            android:title="Flash Brightness"
            android:summary="Adjust flash intensity (requires Android 13+)"
            android:defaultValue="1"
            android:inputType="number" />
    </PreferenceCategory>

    <PreferenceCategory android:title="Stream Settings">
        <EditTextPreference
            android:key="stream_scale"
            android:title="Output Scale"
            android:summary="Scale output JPEG (0.5 - 2.0)"
            android:defaultValue="1.0"
            android:inputType="numberDecimal" />
        <EditTextPreference
            android:key="stream_delay"
            android:title="Frame Interval (ms)"
            android:summary="Delay between frames (10-1000)"
            android:defaultValue="33"
            android:inputType="number" />
    </PreferenceCategory>
</PreferenceScreen>
